# AACode 环境变量配置示例
# 复制此文件为 .env 并填写你的实际配置

# 主要LLM配置（支持OpenAI兼容API，LLM网关支持openai和anthropic）
LLM_API_KEY=your_api_key_here
LLM_API_URL=https://api.deepseek.com/v1
LLM_MODEL_NAME=deepseek-chat
LLM_GATEWAY=openai
LLM_MULTIMODAL=false  # 是否启用多模态支持（true/false）

# 可选：多模态模型配置（支持Kimi、MiniMax等）
MULTIMODAL_API_KEY=your_multimodal_api_key_here
MULTIMODAL_API_URL=https://api.moonshot.cn/v1

# 可选：搜索配置
SEARCH_API_URL=http://192.168.0.106:8081
SEARCH_ENGINE=searxng

# 可选：沙箱配置
SANDBOX_TYPE=docker

# 可选：安全配置
ALLOW_NETWORK=true
RESTRICT_TO_PROJECT=true